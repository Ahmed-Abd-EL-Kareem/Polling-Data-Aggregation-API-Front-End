VITE_API_URL=http://localhost:3000

# Cloudinary — browser upload (unsigned preset)
# VITE_CLOUDINARY_CLOUD_NAME = "Cloud name" on the dashboard home (short id, e.g. duzrt26dy). NOT your API key. NOT the preset name.
